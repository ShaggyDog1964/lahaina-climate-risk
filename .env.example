# FRED API key — obtain at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Census API key — obtain at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# PostgreSQL/PostGIS connection string (matches docker-compose defaults)
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/lahaina

# ClickHouse connection
CH_HOST=localhost
CH_PORT=9000

# Comma-separated list of allowed CORS origins for the API
CORS_ORIGINS=http://localhost:3000
